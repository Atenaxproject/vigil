# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git

# Supabase — get from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin access — comma-separated emails allowed to access /admin
VIGIL_ADMIN_EMAILS=

# Security — random secret for IP hashing and internal checks
VIGIL_ADMIN_SECRET=

# Optional integrations
# RESEND_API_KEY — outbound alerts; verify sending domain youthewave.org in Resend (not youtheway.org)
ANTHROPIC_API_KEY=
# Optional: route Anthropic via Vercel AI Gateway for spend visibility
# ANTHROPIC_BASE_URL=
# AI circuit breaker — request-count proxy units (sonnet=10, haiku=1). Tunable live without redeploy.
# AI_DEGRADE_THRESHOLD=800
# AI_HALT_THRESHOLD=2000
CRON_SECRET=
RESEND_API_KEY=
MAKE_WEBHOOK_SECRET=

# Desaparecidos Terremoto Venezuela — federated search (read-only, no data stored)
DTV_API_BASE_URL=
DTV_API_KEY=
